{
  "buildCommand": "cd dashboard && npm install && npm run build",
  "outputDirectory": "dashboard/dist",
  "crons": [
    {
      "path": "/api/reconcile?alert=1",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/nudge-cron",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/weekly-summary",
      "schedule": "0 8 * * 5"
    },
    {
      "path": "/api/daily-report",
      "schedule": "15 6 * * *"
    },
    {
      "path": "/api/weekly-pulse",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/ig-snapshot",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/fb-page-snapshot",
      "schedule": "5 4 * * *"
    }
  ],
  "rewrites": [
    { "source": "/view", "destination": "/index.html" },
    { "source": "/view/", "destination": "/index.html" },
    { "source": "/view/:path*", "destination": "/index.html" },
    { "source": "/signup", "destination": "/index.html" },
    { "source": "/signup/", "destination": "/index.html" },
    { "source": "/signup/:path*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/view/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
